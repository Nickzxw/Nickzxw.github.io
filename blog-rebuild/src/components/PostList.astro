---
import PostCard from './PostCard.astro';

interface Post {
  slug: string;
  title: string;
  description: string;
  cover?: string;
  date: string;
  categories?: string[];
}

interface Props {
  posts: Post[];
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;
---

<div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {posts.map(post => (
      <PostCard {...post} />
    ))}
  </div>

  {totalPages > 1 && (
    <nav class="flex justify-center items-center gap-2 mt-12">
      {currentPage > 1 && (
        <a
          href={`/?page=${currentPage - 1}`}
          class="px-4 py-2 rounded-lg border border-[#E5E5E5] dark:border-[#2a2a4a] hover:bg-[#f5f5f5] dark:hover:bg-[#16213E] transition-colors"
        >
          ← 上一页
        </a>
      )}

      <div class="flex items-center gap-1">
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
          <a
            href={`/?page=${page}`}
            class={`w-10 h-10 flex items-center justify-center rounded-lg transition-colors ${
              page === currentPage
                ? 'bg-primary text-white'
                : 'border border-[#E5E5E5] dark:border-[#2a2a4a] hover:bg-[#f5f5f5] dark:hover:bg-[#16213E]'
            }`}
          >
            {page}
          </a>
        ))}
      </div>

      {currentPage < totalPages && (
        <a
          href={`/?page=${currentPage + 1}`}
          class="px-4 py-2 rounded-lg border border-[#E5E5E5] dark:border-[#2a2a4a] hover:bg-[#f5f5f5] dark:hover:bg-[#16213E] transition-colors"
        >
          下一页 →
        </a>
      )}
    </nav>
  )}
</div>